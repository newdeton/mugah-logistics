<%- include("../partials/header") %>

<!-- Fleet Hero -->
<section class="fleet-hero">

    <div class="fleet-overlay"></div>

    <div class="fleet-hero-content">

        <h1>Our Premium Fleet</h1>

        <p>
            Browse our collection of reliable, comfortable and professionally
            maintained vehicles for every journey.
        </p>

    </div>

<section class="fleet-search">

<form method="GET" action="/fleet">

    <select name="category">

    <option value="">All Categories</option>

    <option value="Sedan" <%= filters.category === "Sedan" ? "selected" : "" %>>Sedan</option>

    <option value="SUV" <%= filters.category === "SUV" ? "selected" : "" %>>SUV</option>

    <option value="Van" <%= filters.category === "Van" ? "selected" : "" %>>Van</option>

    <option value="Pickup" <%= filters.category === "Pickup" ? "selected" : "" %>>Pickup</option>

    <option value="Luxury" <%= filters.category === "Luxury" ? "selected" : "" %>>Luxury</option>

    <option value="Bus" <%= filters.category === "Bus" ? "selected" : "" %>>Bus</option>

</select>

    <select name="brand">

    <option value="">All Brands</option>

    <option value="Toyota" <%= filters.brand === "Toyota" ? "selected" : "" %>>Toyota</option>

    <option value="Nissan" <%= filters.brand === "Nissan" ? "selected" : "" %>>Nissan</option>

    <option value="Mazda" <%= filters.brand === "Mazda" ? "selected" : "" %>>Mazda</option>

    <option value="Subaru" <%= filters.brand === "Subaru" ? "selected" : "" %>>Subaru</option>

    <option value="Mercedes-Benz" <%= filters.brand === "Mercedes-Benz" ? "selected" : "" %>>Mercedes-Benz</option>

    <option value="BMW" <%= filters.brand === "BMW" ? "selected" : "" %>>BMW</option>

    <option value="Audi" <%= filters.brand === "Audi" ? "selected" : "" %>>Audi</option>

    <option value="Volkswagen" <%= filters.brand === "Volkswagen" ? "selected" : "" %>>Volkswagen</option>

    <option value="Land Rover" <%= filters.brand === "Land Rover" ? "selected" : "" %>>Land Rover</option>

    <option value="Lexus" <%= filters.brand === "Lexus" ? "selected" : "" %>>Lexus</option>

    <option value="Mitsubishi" <%= filters.brand === "Mitsubishi" ? "selected" : "" %>>Mitsubishi</option>

    <option value="Isuzu" <%= filters.brand === "Isuzu" ? "selected" : "" %>>Isuzu</option>

    <option value="Ford" <%= filters.brand === "Ford" ? "selected" : "" %>>Ford</option>

    <option value="Honda" <%= filters.brand === "Honda" ? "selected" : "" %>>Honda</option>

</select>

    <select name="transmission">

    <option value="">Transmission</option>

    <option value="Automatic" <%= filters.transmission === "Automatic" ? "selected" : "" %>>

        Automatic

    </option>

    <option value="Manual" <%= filters.transmission === "Manual" ? "selected" : "" %>>

        Manual

    </option>

</select>

    <input
        type="number"
        name="minPrice"
        placeholder="Min Price"
        value="<%= filters.minPrice || '' %>">

    <input
        type="number"
        name="maxPrice"
        placeholder="Max Price"
        value="<%= filters.maxPrice || '' %>">

    <label>

        <input
            type="checkbox"
            name="available"
            value="true"
            <%= filters.available ? "checked" : "" %>>

        Available Only

    </label>

    <button class="btn">

        Search

    </button>

</form>

</section>

<!-- Fleet Vehicles -->

<section class="fleet-list">

    <div class="fleet-grid">

        <% if (cars.length > 0) { %>

            <% cars.forEach(car => { %>

                <div class="car-card">

                    <img
                        src="<%= car.images.length ? car.images[0] : '/images/no-car.jpg' %>"
                        alt="<%= car.name %>">

                    <div class="car-info">

                        <h3><%= car.name %></h3>

                        <p class="price">
                            KSh <%= car.dailyRate.toLocaleString() %> / Day
                        </p>

                        <div class="features">

                            <span>👥 <%= car.seats %> Seats</span>

                            <span>⚙ <%= car.transmission %></span>

                            <span>⛽ <%= car.fuelType %></span>

                        </div>

                        <% if(car.available){ %>

                            <span class="badge available">
                                Available
                            </span>

                        <% } else { %>

                            <span class="badge booked">
                                Booked
                            </span>

                        <% } %>

                        <div class="card-buttons">

                            <a href="/fleet/<%= car._id %>" class="btn-outline">
    View Details
</a>

                            <a href="/booking/<%= car._id %>" class="btn">
                                Book Now
                            </a>

                        </div>

                    </div>

                </div>

            <% }) %>

        <% } else { %>

            <h2>No vehicles available.</h2>

        <% } %>

    </div>

</section>

<%- include("../partials/footer") %>