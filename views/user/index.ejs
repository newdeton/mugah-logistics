<%- include("../partials/header") %>

<!-- HERO -->
<section class="hero">

    <div class="overlay"></div>

    <div class="hero-content">

        <h1>Drive Your Journey With Confidence at MUGAH LOGISTICS</h1>

        <p>
            Premium car hire services for business, travel,
            airport transfers and special occasions.
        </p>

        <div class="hero-buttons">
            <a href="/booking" class="btn">Book Now</a>
            <a href="#fleet" class="btn-outline">View Fleet</a>
        </div>

    </div>

</section>

<!-- QUICK BOOKING -->

<section class="quick-booking">

    <form>

        <input type="text" placeholder="Pickup Location" required>

        <input type="date" required>

        <input type="date" required>

        <select>
            <option>Select Vehicle</option>
            <option>Sedan</option>
            <option>SUV</option>
            <option>Luxury</option>
            <option>Van</option>
        </select>

        <select>
            <option>Driver Needed?</option>
            <option>Yes</option>
            <option>No</option>
        </select>

        <button type="submit">
            Search Cars
        </button>

    </form>

</section>

<!-- FEATURED FLEET -->

<section class="fleet" id="fleet">

    <div class="section-title">
        <h2>Featured Fleet</h2>
        <p>Choose from our premium collection of well-maintained vehicles.</p>
    </div>

    <div class="fleet-grid">

        <div class="car-card">

            <img src="/images/premio.jpg" alt="Toyota Premio">

            <div class="car-info">
                <h3>Toyota Premio</h3>

                <p>KSh 3,500 / Day</p>

                <div class="features">
                    <span>👥 5 Seats</span>
                    <span>⚙ Automatic</span>
                    <span>⛽ Petrol</span>
                </div>

                <a href="/booking" class="btn">Book Now</a>

            </div>

        </div>

        <div class="car-card">

            <img src="/images/prado.jpg" alt="Toyota Prado">

            <div class="car-info">
                <h3>Toyota Prado TX</h3>

                <p>KSh 12,000 / Day</p>

                <div class="features">
                    <span>👥 7 Seats</span>
                    <span>⚙ Automatic</span>
                    <span>⛽ Diesel</span>
                </div>

                <a href="/booking" class="btn">Book Now</a>

            </div>

        </div>

        <div class="car-card">

            <img src="/images/demio.jpg" alt="Mazda Demio">

            <div class="car-info">
                <h3>Mazda Demio</h3>

                <p>KSh 2,800 / Day</p>

                <div class="features">
                    <span>👥 5 Seats</span>
                    <span>⚙ Automatic</span>
                    <span>⛽ Petrol</span>
                </div>

                <a href="/booking" class="btn">Book Now</a>

            </div>

        </div>

        <div class="car-card">

            <img src="/images/noah.jpg" alt="Toyota Noah">

            <div class="car-info">
                <h3>Toyota Noah</h3>

                <p>KSh 6,500 / Day</p>

                <div class="features">
                    <span>👥 8 Seats</span>
                    <span>⚙ Automatic</span>
                    <span>⛽ Petrol</span>
                </div>

                <a href="/booking" class="btn">Book Now</a>

            </div>

        </div>

    </div>

</section>

