<%- include("../partials/header") %>

<!-- HERO -->
<section class="hero">

    <div class="overlay"></div>

    <div class="hero-content">

        <h1>Drive Your Journey With Confidence at MUGAH LOGISTICS</h1>

        <p>
            Premium car hire services for business, travel,
            airport transfers and special occasions.
        </p>

        <div class="hero-buttons">
            <a href="/booking" class="btn">
    Book Now
</a>
            <a href="#fleet" class="btn-outline">View Fleet</a>
        </div>

    </div>

</section>

<!-- QUICK BOOKING -->

<section class="quick-booking">

    <form>

        <input type="text" placeholder="Pickup Location" required>

        <input type="date" required>

        <input type="date" required>

        <select name="car">

    <option value="">Select Vehicle</option>

    <% cars.forEach(car => { %>

        <option value="<%= car._id %>">
            <%= car.name %> - KSh <%= car.dailyRate.toLocaleString() %>/Day
        </option>

    <% }) %>

</select>

        <select>
            <option>Driver Needed?</option>
            <option>Yes</option>
            <option>No</option>
        </select>

        <button type="submit">
            Search Cars
        </button>

    </form>

</section>

<!-- FEATURED FLEET -->

<section class="fleet" id="fleet">

    <div class="section-title">
        <h2>Featured Fleet</h2>
        <p>Choose from our premium collection of well-maintained vehicles.</p>
    </div>

    <div class="fleet-grid">

        <% if (cars && cars.length > 0) { %>

            <% cars.forEach(car => { %>

                <div class="car-card">

                    <a href="/booking/<%= car._id %>">

                        <img
                            src="<%= (car.images && car.images.length > 0) ? car.images[0] : '/images/no-car.jpg' %>"
                            alt="<%= car.name %>">

                    </a>

                    <div class="car-info">

                        <h3><%= car.name %></h3>

                        <p>KSh <%= car.dailyRate.toLocaleString() %> / Day</p>

                        <div class="features">

                            <span>👥 <%= car.seats %> Seats</span>

                            <span>⚙ <%= car.transmission %></span>

                            <span>⛽ <%= car.fuelType %></span>

                        </div>

                        <a href="/booking/<%= car._id %>" class="btn">
                            Book Now
                        </a>

                    </div>

                </div>

            <% }) %>

        <% } else { %>

            <div style="width:100%;text-align:center;padding:40px;">

                <h3>No vehicles available at the moment.</h3>

            </div>

        <% } %>

    </div>

</section>

<!-- STATS -->

<section class="stats">

    <div class="stat-box">
        <h2>500+</h2>
        <p>Successful Rentals</p>
    </div>

    <div class="stat-box">
        <h2>100+</h2>
        <p>Happy Clients</p>
    </div>

    <div class="stat-box">
        <h2>20+</h2>
        <p>Premium Vehicles</p>
    </div>

    <div class="stat-box">
        <h2>24/7</h2>
        <p>Customer Support</p>
    </div>

</section>

<!-- SERVICES -->

<section class="services">

    <div class="section-title">
        <h2>Our Services</h2>
        <p>Professional transport solutions tailored to your needs.</p>
    </div>

    <div class="services-grid">

        <div class="service-card">
            <i class="fas fa-car"></i>
            <h3>Self Drive</h3>
            <p>Rent a vehicle and enjoy the freedom to travel at your own pace.</p>
        </div>

        <div class="service-card">
            <i class="fas fa-user-tie"></i>
            <h3>Chauffeur Service</h3>
            <p>Professional, experienced drivers for business and personal travel.</p>
        </div>

        <div class="service-card">
            <i class="fas fa-plane-arrival"></i>
            <h3>Airport Transfers</h3>
            <p>Reliable airport pickups and drop-offs with punctual service.</p>
        </div>

        <div class="service-card">
            <i class="fas fa-briefcase"></i>
            <h3>Corporate Hire</h3>
            <p>Executive transport solutions for companies and business events.</p>
        </div>

        <div class="service-card">
            <i class="fas fa-ring"></i>
            <h3>Wedding Cars</h3>
            <p>Luxury vehicles to make your special day elegant and memorable.</p>
        </div>

        <div class="service-card">
            <i class="fas fa-road"></i>
            <h3>Long-Term Leasing</h3>
            <p>Flexible monthly rental plans for individuals and organizations.</p>
        </div>

    </div>

</section>

<!-- TESTIMONIALS -->

<section class="testimonials">

    <div class="section-title">
        <h2>What Our Clients Say</h2>
        <p>Trusted by individuals, families and businesses across Kenya.</p>
    </div>

    <div class="testimonial-grid">

        <div class="testimonial-card">
            <p>
                "Excellent customer service and very clean vehicles.
                I highly recommend MUGAH LOGISTICS."
            </p>

            <h4>— James Mwangi</h4>
        </div>

        <div class="testimonial-card">
            <p>
                "Booking was quick and the airport pickup was on time.
                Outstanding experience."
            </p>

            <h4>— Faith Wanjiku</h4>
        </div>

        <div class="testimonial-card">
            <p>
                "Affordable prices and professional drivers.
                Definitely using them again."
            </p>

            <h4>— Brian Otieno</h4>
        </div>

    </div>

</section>

<!-- CALL TO ACTION -->

<section class="cta">

    <h2>Ready to Book Your Next Ride?</h2>

    <p>
        Premium vehicles, competitive prices and exceptional customer service.
    </p>

    <a href="/booking" class="btn">
        Book Your Vehicle
    </a>

</section>

<%- include("../partials/footer") %>