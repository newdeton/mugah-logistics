```ejs
<%- include("../partials/header") %>

<section class="page-header">

    <div class="page-content">

        <h1>Request Any Vehicle</h1>

        <p>
            Can't find the vehicle you need in our fleet?
            Tell us what you're looking for and we'll source it for you.
        </p>

    </div>

</section>

<section class="booking-section">

    <div class="booking-container">

        <% if(error){ %>

            <div class="alert alert-danger">
                <%= error %>
            </div>

        <% } %>

        <form action="/booking/book-now" method="POST" class="booking-form">

            <div class="booking-grid">

                <!-- Customer Information -->
                <div class="booking-card">

                    <h2>
                        <i class="fas fa-user"></i>
                        Customer Information
                    </h2>

                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" name="fullName" required>
                    </div>

                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" name="email" required>
                    </div>

                    <div class="form-group">
                        <label>Phone Number</label>
                        <input type="text" name="phone" required>
                    </div>

                </div>

                <!-- Vehicle Request -->
                <div class="booking-card">

                    <h2>
                        <i class="fas fa-car"></i>
                        Vehicle Request
                    </h2>

                    <div class="form-group">

                        <label>Category</label>

                        <select name="requestedCategory">

                            <option value="">Select Category</option>
                            <option>Sedan</option>
                            <option>SUV</option>
                            <option>Van</option>
                            <option>Pickup</option>
                            <option>Luxury</option>
                            <option>Bus</option>

                        </select>

                    </div>

                    <div class="form-group">

                        <label>Brand</label>

                        <select name="requestedBrand">

                            <option value="">Select Brand</option>
                            <option>Toyota</option>
                            <option>Nissan</option>
                            <option>Mazda</option>
                            <option>Mercedes-Benz</option>
                            <option>BMW</option>
                            <option>Audi</option>
                            <option>Land Rover</option>
                            <option>Lexus</option>
                            <option>Ford</option>
                            <option>Isuzu</option>

                        </select>

                    </div>

                    <div class="form-group">

                        <label>Model</label>

                        <input
                            type="text"
                            name="requestedModel">

                    </div>

                    <div class="form-group">

                        <label>Transmission</label>

                        <select name="requestedTransmission">

                            <option value="">Transmission</option>

                            <option>Automatic</option>

                            <option>Manual</option>

                        </select>

                    </div>

                    <div class="form-group">

                        <label>Seats</label>

                        <input
                            type="number"
                            name="requestedSeats">

                    </div>

                </div>

            </div>

            <div class="booking-card">

                <h2>

                    <i class="fas fa-calendar-alt"></i>

                    Booking Details

                </h2>

                <div class="booking-grid">

                    <div class="form-group">

                        <label>Pickup Location</label>

                        <input
                            type="text"
                            name="pickupLocation"
                            required>

                    </div>

                    <div class="form-group">

                        <label>Driver Required?</label>

                        <select name="driverRequired">

                            <option value="No">
                                No
                            </option>

                            <option value="Yes">
                                Yes
                            </option>

                        </select>

                    </div>

                    <div class="form-group">

                        <label>Pickup Date</label>

                        <input
                            type="date"
                            name="pickupDate"
                            required>

                    </div>

                    <div class="form-group">

                        <label>Return Date</label>

                        <input
                            type="date"
                            name="returnDate"
                            required>

                    </div>

                </div>

                <div class="form-group">

                    <label>Special Requests</label>

                    <textarea
                        name="notes"
                        rows="5"></textarea>

                </div>

                <div class="booking-submit">

                    <button
                        class="btn"
                        type="submit">

                        <i class="fas fa-paper-plane"></i>

                        Submit Booking Request

                    </button>

                </div>

            </div>

        </form>

    </div>

</section>
<%- include("../partials/footer") %>
```
